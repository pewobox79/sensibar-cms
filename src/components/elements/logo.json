{
  "collectionName": "components_elements_logos",
  "info": {
    "displayName": "logo"
  },
  "options": {},
  "attributes": {
    "src": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "hasLink": {
      "type": "boolean",
      "default": false
    },
    "alt": {
      "type": "string"
    },
    "target": {
      "type": "enumeration",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "hasLink"
            },
            true
          ]
        }
      },
      "enum": [
        "_self",
        "_blank"
      ]
    },
    "href": {
      "type": "string",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "hasLink"
            },
            true
          ]
        }
      }
    }
  }
}
